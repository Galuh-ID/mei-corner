---
import { getCollection, render } from 'astro:content';
import RecruiterLayout from '../../layouts/RecruiterLayout.astro';
import Prose from '../../components/ui/Prose.astro';

export async function getStaticPaths() {
    const projects = await getCollection('projects');
    return projects.map(project => ({
        params: { slug: project.data.slug },
        props: { project },
    }));
}

const { project } = Astro.props;
const { Content } = await render(project);
---

<RecruiterLayout title={project.data.title}>
    <article class="mb-20">
        <header class="mb-12">
        <h1 class="text-5xl font-black uppercase tracking-tighter mb-4">{project.data.title}</h1>
            <div class="flex gap-2">
                {project.data.tags.map((tag: string) => (
                    <span class="border-2 border-black px-3 py-1 font-bold uppercase text-sm tracking-widest">
                        {tag}
                    </span>
                ))}
            </div>
        </header>
        
        <Prose>
            <Content />
        </Prose>
    </article>
</RecruiterLayout>