---
import 'katex/dist/katex.min.css';
---

<div class="prose-container max-w-4xl mx-auto w-full">
    <slot />
</div>

<style is:global>
    .prose-container h1,
    .prose-container h2,
    .prose-container h3,
    .prose-container h4 {
        font-family: var(--font-heading);
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: -0.05em;
        color: var(--color-text-primary);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
    }

    .prose-container h1 { font-size: 3rem; line-height: 1; border-bottom: 8px solid var(--color-border); padding-bottom: 0.5rem; }
    .prose-container h2 { font-size: 2.25rem; border-bottom: 4px solid var(--color-border); padding-bottom: 0.5rem; }
    .prose-container h3 { font-size: 1.5rem; }

    .prose-container p {
        font-family: var(--font-body);
        font-size: 1.125rem;
        line-height: 1.75;
        margin-bottom: 1.5rem;
        color: var(--color-text-primary);
    }

    .prose-container strong { font-weight: 900; }

    .prose-container blockquote {
        border-left: 8px solid var(--color-border);
        padding-left: 1.5rem;
        font-style: italic;
        font-weight: 700;
        margin: 2rem 0;
        background-color: var(--color-bg);
    }

    .prose-container pre {
        background-color: var(--color-text-primary) !important;
        color: var(--color-bg) !important;
        padding: 1.5rem;
        border: 4px solid var(--color-border);
        box-shadow: 8px 8px 0px 0px var(--color-border);
        overflow-x: auto;
        margin-bottom: 2rem;
        font-size: 0.9rem;
    }

    .prose-container code {
        font-family: monospace;
        font-weight: bold;
    }
</style>